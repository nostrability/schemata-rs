{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "NIP-90 amount tag for job results: ['amount', '<millisats>', '<optional-bolt11>']",
  "allOf": [
    {
      "allOf": [
        {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": false
        }
      ]
    },
    {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": [
        {
          "const": "amount"
        },
        {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Amount charged in millisats"
        },
        {
          "type": "string",
          "minLength": 1,
          "description": "Optional bolt11 invoice"
        }
      ],
      "additionalItems": false,
      "errorMessage": {
        "minItems": "amount tag must have at least 2 elements"
      }
    }
  ],
  "$id": "https://nostrability.github.io/schemata/tag/nip-90_amount.json"
}