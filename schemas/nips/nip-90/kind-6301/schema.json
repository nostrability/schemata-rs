          "allOf": [
            {
              "contains": {
                "allOf": [
                  {
                    "$schema": "http://json-schema.org/draft-07/schema#",
                    "allOf": [
                      {
                        "allOf": [
                          {
                            "$schema": "http://json-schema.org/draft-07/schema#",
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "uniqueItems": false
                          }
                        ]
                      }
                    ],
                    "oneOf": [
                      {
                        "type": "array",
                        "minItems": 4,
                        "maxItems": 5,
                        "items": [
                          {
                            "const": "e"
                          },
                          {
                            "type": "string",
                            "pattern": "^[a-f0-9]{64}$"
                          },
