            },
            {
              "if": {
                "contains": {
                  "type": "array",
                  "items": [
                    {
                      "const": "request"
                    }
                  ]
                }
              },
              "then": {
                "contains": {
                  "allOf": [
                    {
                      "$schema": "http://json-schema.org/draft-07/schema#",
                      "allOf": [
                        {
                          "allOf": [
                            {
                              "$schema": "http://json-schema.org/draft-07/schema#",
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "uniqueItems": false
                            }
                          ]
                        },
                        {
                          "type": "array",
                          "minItems": 2,
                          "maxItems": 2,
                          "items": [
                            {
                              "const": "request"
                            },
                            {
                              "type": "string",
                              "minLength": 1,
                              "description": "JSON-encoded original job request event"
                            }
                          ],
                          "additionalItems": false
