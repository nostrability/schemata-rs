                              "root"
                            ]
                          },
                          {
                            "allOf": [
                              {
                                "$schema": "http://json-schema.org/draft-07/schema#",
                                "type": "string",
                                "pattern": "^[a-f0-9]{64}$"
                              }
                            ]
                          }
                        ],
                        "additionalItems": false
                      },
                      {
                        "type": "array",
                        "minItems": 2,
                        "maxItems": 3,
                        "items": [
                          {
                            "const": "e"
                          },
                          {
                            "type": "string",
                            "pattern": "^[a-f0-9]{64}$"
                          },
                          {
                            "type": "string",
                            "pattern": "^(ws://|wss://).+$"
                          }
                        ],
                        "additionalItems": false
                      }
                    ]
                  }
                ]
              },
              "errorMessage": {
                "contains": "tags must include an e tag referencing the job request event"
