              }
            },
            {
              "if": {
                "contains": {
                  "type": "array",
                  "items": [
                    {
                      "const": "merge-base"
                    }
                  ]
                }
              },
              "then": {
                "contains": {
                  "allOf": [
                    {
                      "$schema": "http://json-schema.org/draft-07/schema#",
                      "allOf": [
                        {
                          "allOf": [
                            {
                              "$schema": "http://json-schema.org/draft-07/schema#",
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "uniqueItems": false
                            }
                          ]
                        },
                        {
                          "type": "array",
                          "minItems": 2,
                          "maxItems": 2,
                          "items": [
                            {
                              "const": "merge-base"
                            },
