                            "uniqueItems": false
                          }
                        ]
                      },
                      {
                        "type": "array",
                        "minItems": 2,
                        "items": [
                          {
                            "const": "a"
                          },
                          {
                            "type": "string",
                            "pattern": "^\\d+:[a-f0-9]{64}:.+$"
