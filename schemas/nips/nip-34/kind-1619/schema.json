            "created_at",
            "id",
            "kind",
            "pubkey",
            "sig",
            "tags"
          ],
          "additionalProperties": false
        }
      ]
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "const": 1619,
          "errorMessage": "kind must equal 1619"
        },
        "tags": {
          "type": "array",
          "items": {
            "allOf": [
              {
                "$schema": "http://json-schema.org/draft-07/schema#",
