                "items": {
                  "type": "string"
                },
                "uniqueItems": false
              }
            ]
          },
          "minItems": 1,
          "allOf": [
            {
              "contains": {
                "allOf": [
                  {
                    "$schema": "http://json-schema.org/draft-07/schema#",
                    "allOf": [
                      {
                        "allOf": [
                          {
