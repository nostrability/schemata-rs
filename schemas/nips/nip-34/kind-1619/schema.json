                    ]
                  }
                ]
              },
              "errorMessage": {
                "contains": "tags must include an a tag referencing the target repository"
              }
            },
            {
              "contains": {
                "allOf": [
                  {
                    "$schema": "http://json-schema.org/draft-07/schema#",
                    "allOf": [
                      {
                        "allOf": [
                          {
                            "$schema": "http://json-schema.org/draft-07/schema#",
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "uniqueItems": false
                          }
                        ]
                      },
                      {
                        "type": "array",
                        "minItems": 2,
                        "items": [
                          {
                            "const": "p"
                          },
                          {
                            "allOf": [
                              {
                                "$schema": "http://json-schema.org/draft-07/schema#",
                                "type": "string",
                                "pattern": "^[a-f0-9]{64}$"
