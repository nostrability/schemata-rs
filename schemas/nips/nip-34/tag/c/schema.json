{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "allOf": [
        {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": false
        }
      ]
    },
    {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": [
        {
          "const": "c"
        },
        {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$",
          "description": "Git commit hash (40 hex chars)"
        }
      ],
      "additionalItems": false,
      "errorMessage": {
        "minItems": "c tag must have at least 2 elements"
      }
    }
  ],
  "$id": "https://nostrability.github.io/schemata/tag/c.json"
}