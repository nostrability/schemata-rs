              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": [
            {
              "const": "e"
            },
            {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^(ws://|wss://).+$"
                },
                {
                  "type": "string",
                  "const": ""
                }
              ]
            },
            {
              "allOf": [
                {
                  "$schema": "http://json-schema.org/draft-07/schema#",
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                }
              ]
            }
          ],
          "additionalItems": false
        }
      ]
    }
  ]
}