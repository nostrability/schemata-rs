{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": [
            {
              "const": "commit-pgp-sig"
            },
            {
              "anyOf": [
                {
                  "type": "string",
                  "const": ""
                },
                {
                  "type": "string",
                  "pattern": "^\\-\\-\\-\\-\\-BEGIN PGP SIGNATURE\\-\\-\\-\\-\\-[\\s\\S]*\\-\\-\\-\\-\\-END PGP SIGNATURE\\-\\-\\-\\-\\-$"
                }
              ]
            }
          ],
          "additionalItems": false
        }
      ]
    }
  ]
}